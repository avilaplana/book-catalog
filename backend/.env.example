# Copy to .env and fill in. .env is gitignored.

# Google OAuth Client ID (the audience claim of Google ID tokens). NOT a secret.
GOOGLE_CLIENT_ID=

# Symmetric secret for signing our own access/refresh JWTs (HS256).
# Pick something random and at least 32 bytes; e.g. `openssl rand -hex 32`.
JWT_SECRET=

# Async SQLAlchemy URL for local Postgres started by docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://colophon:colophon@localhost:5433/colophon
