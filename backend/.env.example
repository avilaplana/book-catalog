# Copy to .env and fill in. .env is gitignored.

# Google OAuth Client ID(s) — the audience claim of Google ID tokens. NOT a secret.
# Accepts a comma-separated list to allow multiple clients (e.g. web + iOS + Android).
GOOGLE_CLIENT_ID=

# Symmetric secret for signing our own access/refresh JWTs (HS256).
# Pick something random and at least 32 bytes; e.g. `openssl rand -hex 32`.
JWT_SECRET=

# Async SQLAlchemy URL for local Postgres started by docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://colophon:colophon@localhost:5433/colophon

# Google Books API key. Optional but recommended: without it the backend hits
# the anonymous Google Books endpoint, which shares a project-level daily
# quota and is easily exhausted in development. Provision in GCP →
# Credentials → API key, with the Books API enabled. Restrict the key to the
# Books API in the console.
GOOGLE_BOOKS_API_KEY=
