# Copy to .env and fill in. .env is gitignored.
# Anything prefixed EXPO_PUBLIC_ is baked into the JS bundle at build time.

# Backend base URL the mobile app talks to.
# iOS Simulator + web target: http://localhost:8000
# Android Emulator: http://10.0.2.2:8000
# Physical device on the same LAN: http://<your-machine-ip>:8000
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth Web Client ID — used as the audience on the web target.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Google OAuth iOS Client ID. Required to run the sign-in flow on the
# iOS Simulator or any iOS device (web alone won't satisfy expo-auth-session
# on native iOS). Provision in GCP → Credentials → OAuth client → iOS, with
# bundle ID `host.exp.Exponent` for Expo Go, or your own bundle ID for an
# EAS standalone build. Add the same value to backend GOOGLE_CLIENT_ID
# (comma-separated) so the backend accepts the resulting tokens.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Google OAuth Android Client ID. Same idea as iOS, for Android builds.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
