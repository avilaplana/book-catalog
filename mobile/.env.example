# Copy to .env and fill in. .env is gitignored.
# Anything prefixed EXPO_PUBLIC_ is baked into the JS bundle at build time.

# Backend base URL the mobile app talks to.
# iOS Simulator + web target: http://localhost:8000
# Android Emulator: http://10.0.2.2:8000
# Physical device on the same LAN: http://<your-machine-ip>:8000
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth Web Client ID — same value as backend's GOOGLE_CLIENT_ID for
# the Expo Go / dev-client flow. Standalone iOS/Android builds need their
# own platform-specific client IDs added to useGoogleSignIn().
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
